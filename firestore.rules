rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is TL
    function isTL() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tl';
    }

    // Helper function to check if user is TL of a project
    function isProjectTL(projectId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/projects/$(projectId)) &&
             get(/databases/$(database)/documents/projects/$(projectId)).data.tlId == request.auth.uid;
    }

    // Helper function to check if user is member of a team
    function isTeamMember(teamId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/teams/$(teamId)) &&
             request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
    }

    // Tasks collection - users can access their own tasks, admins can access all
    match /tasks/{taskId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null &&
                       (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Users collection - authenticated users can read all, write their own or admins
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      (request.auth.uid == userId || isAdmin());
    }

    // Teams collection - admins can read/write all, TLs can read their teams
    match /teams/{teamId} {
      allow read: if request.auth != null &&
                     (isAdmin() || isTeamMember(teamId) || isTL());
      allow write: if request.auth != null && isAdmin();
    }

    // Projects collection - admins can read/write all, TLs can read/write their own projects
    match /projects/{projectId} {
      allow read: if request.auth != null &&
                     (isAdmin() || (isTL() && resource.data.tlId == request.auth.uid));
      allow write: if request.auth != null &&
                      (isAdmin() || (isTL() && resource.data.tlId == request.auth.uid));
    }

    // Activity logs - admins can read/write all
    match /activity_logs/{logId} {
      allow read, write: if request.auth != null && isAdmin();
    }
  }
}
